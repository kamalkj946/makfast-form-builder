# Shopify App Credentials (from Shopify Partners Dashboard)
SHOPIFY_API_KEY=your_shopify_api_key
SHOPIFY_API_SECRET=your_shopify_api_secret
SCOPES=write_products,read_themes,write_metafields,read_metafields

# App URL (your Vercel deployment URL)
SHOPIFY_APP_URL=https://your-app.vercel.app

# Database (Neon.tech Free Tier PostgreSQL)
DATABASE_URL=postgresql://username:password@ep-xxx.us-east-2.aws.neon.tech/makfast?sslmode=require

# Resend Email (Free Tier - 3000 emails/month)
RESEND_API_KEY=your_resend_api_key

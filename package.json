{
  "name": "makfast-form-builder",
  "private": true,
  "sideEffects": false,
  "type": "module",
  "scripts": {
    "build": "remix vite:build",
    "dev": "shopify app dev",
    "docker-start": "npm run setup && remix vite:build && remix-serve ./build/server/index.js",
    "generate": "shopify app generate",
    "deploy": "shopify app deploy",
    "config:link": "shopify app config link",
    "config:push": "shopify app config push",
    "env": "shopify app env",
    "start": "remix-serve ./build/server/index.js",
    "lint": "eslint --cache --cache-location ./node_modules/.cache/eslint .",
    "setup": "prisma generate && prisma db push",
    "prisma": "prisma",
    "postinstall": "prisma generate"
  },
  "dependencies": {
    "@prisma/client": "^5.20.0",
    "@remix-run/node": "^2.16.7",
    "@remix-run/react": "^2.16.7",
    "@remix-run/serve": "^2.16.7",
    "@shopify/app-bridge-react": "^4.1.6",
    "@shopify/polaris": "^13.9.0",
    "@shopify/shopify-app-remix": "^3.4.0",
    "@shopify/shopify-api": "^11.7.0",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^9.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "isbot": "^5.1.17",
    "prisma": "^5.20.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "resend": "^4.0.0"
  },
  "devDependencies": {
    "@remix-run/dev": "^2.16.7",
    "@shopify/api-codegen-preset": "^1.1.1",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "typescript": "^5.6.3",
    "vite": "^5.4.11",
    "vite-tsconfig-paths": "^4.3.2",
    "@vercel/remix": "^2.16.7"
  },
  "workspaces": [
    "extensions/*"
  ],
  "engines": {
    "node": ">=20.0.0"
  }
}

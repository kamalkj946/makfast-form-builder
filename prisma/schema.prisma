datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

/// Stores Shopify session tokens for OAuth
model Session {
  id            String    @id
  shop          String
  state         String
  isOnline      Boolean   @default(false)
  scope         String?
  expires       DateTime?
  accessToken   String
  userId        BigInt?
  firstName     String?
  lastName      String?
  email         String?
  accountOwner  Boolean   @default(false)
  locale        String?
  collaborator  Boolean?  @default(false)
  emailVerified Boolean?  @default(false)
}

/// Stores form submissions from customers
model Submission {
  id         String   @id @default(cuid())
  formId     String
  formTitle  String   @default("")
  shopDomain String
  data       Json
  customerEmail String?
  isRead     Boolean  @default(false)
  createdAt  DateTime @default(now())

  @@index([shopDomain])
  @@index([formId])
  @@index([createdAt])
}
